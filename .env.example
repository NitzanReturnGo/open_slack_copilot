# Slack Bot OAuth Token (starts with xoxb-)
# Found under: Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token (starts with xapp-)
# Found under: Slack App → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token

# OpenAI API Key (when llm.provider is openai; default model in config/default.yaml)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# Anthropic API Key (only when llm.provider is anthropic; backend not implemented yet)
# ANTHROPIC_API_KEY=

# Slack app credentials (Basic Information) — only needed for localhost user OAuth:
#   make oauth-server  →  open http://127.0.0.1:8765/slack/oauth/start
# Add the printed Redirect URL under OAuth & Permissions → Redirect URLs.
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# Optional override for redirect (must match Slack app config):
# SLACK_USER_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/slack/oauth/callback
